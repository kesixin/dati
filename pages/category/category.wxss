/* pages/category/category.wxss */
.category-page {
    position: absolute;
    height: 100%;
    width: 100%;
    font-size: 12px;
}
.header {
    width: 100%;
    position: relative;
    font-size: 12px;
    -webkit-overflow-scrolling: touch;
}

.header .text {
    position: absolute;
    left: 0;
    width: 100%;
    color: #fff;
    margin-top: 20rpx;
}
.header .text .title {
    font-size:40rpx;
    margin-bottom:60rpx;
}

.header .text view {
    margin: 0 auto;
    width: 500rpx;
    display: flex;
    justify-content: center;
    text-align: center;
    line-height: 20px;
}

.header image {
    width:750rpx;
    height:280rpx;
    background:#1bd0ad;
}

.header .ok-img {
    width: 15px;
    height: 15px;
    margin-right: 5px;
    margin-top: 3px;
}

.header .ok-wrap {
    padding-bottom: 5px;
}

.header .loading {
    text-align: center;
    position: absolute;
    width: 100%;
    bottom: 170rpx;
    left: 0;
    color: #fff;
}

.header .loading {
    justify-content: center;
    text-align: center;
    align-items: center;
}

.header .lad-img {
    width: 15px;
    height: 15px;
    margin-right: 5px;
    margin-bottom: -3px;
    animation: _loading 1s linear infinite;
}

@-webkit-keyframes _loading {
    0% {
        transform: rotate(0deg);
    }

    100% {
        transform: rotate(360deg);
    }
}

@keyframes _loading {
    0% {
        transform: rotate(0deg);
    }

    100% {
        transform: rotate(360deg);
    }
}
.papers {
    font-size: 14px;
}
.drive {
    margin-top:15px;
}
.drive-wrap {
    margin-left: 10px;
    margin-right: 10px;
    display: flex;
    font-size: 12px;
    flex-wrap: wrap;
}

.dl {
    width: 25%;
    text-align: center;
}

.dt {
    width: 50px;
    height: 50px;
    margin: 10rpx auto;
}

.selected {
  width:40rpx;
  height:40rpx;
  position:relative;
  top:-25px;
  right:-30rpx;
}

.active {
    width: 90%;
    height: 90%;
}

.dd text {
    color: #a0a0a0;
}

.drive-title {
    margin-left: 10px;
    margin-right: 10px;
}

.status-title {
    margin-top: 18px;
}

.footer {
    height: 60px;
    background: #1bd0ad;
    width: 100%;
    position: fixed;
    left: 0;
    bottom: 0;
    text-align: center;
    line-height: 60px;
    font-size: 16px;
    color: #fff;
}